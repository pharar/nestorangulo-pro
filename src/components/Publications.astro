---
import { publications } from '../data/publications';

const typeLabels: Record<string, string> = {
  book_chapter: 'Book Chapter',
  conference_paper: 'Conference Paper',
};

function formatAuthors(coAuthors: string[]): string {
  if (coAuthors.length === 0) return '';
  if (coAuthors.length === 1) return `, & ${coAuthors[0]}`;
  const last = coAuthors[coAuthors.length - 1];
  const rest = coAuthors.slice(0, -1);
  return `, ${rest.join(', ')}, & ${last}`;
}
---

<ol class="publications-list">
  {
    publications.map((p) => (
      <li class="publication-item">
        <p class="publication-authors">
          Angulo de Ugarte, N.
          {p.coAuthors && p.coAuthors.length > 0 && formatAuthors(p.coAuthors)} ({p.year}).
        </p>
        <p class="publication-title">
          {p.title}.{' '}
          {p.in && (
            <>
              In <em>{p.in}</em>.{' '}
            </>
          )}
          {p.venue && (
            <>
              <em>{p.venue}</em>.{' '}
            </>
          )}
          {p.publisher && <>{p.publisher}. </>}
          {p.isbn && <>ISBN {p.isbn}.</>}
        </p>
        <span class="publication-type">{typeLabels[p.type] ?? p.type}</span>
      </li>
    ))
  }
</ol>
