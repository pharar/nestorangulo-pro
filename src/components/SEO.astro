---
interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  ogTitle?: string;
  ogDescription?: string;
  ogImage?: string;
  /** Pass true on the homepage to emit Person structured data */
  person?: boolean;
}

const SITE_URL = 'https://nestorangulo.pro';

const DEFAULT_TITLE =
  'Nestor Angulo de Ugarte — Head of Security · Security Program Builder · CISSP';

const DEFAULT_DESCRIPTION =
  'Building pragmatic security programs from zero inside technical scale-ups. ' +
  'CISSP · Head of Security at Patchstack · 8 years incident response at Sucuri/GoDaddy.';

const DEFAULT_OG_IMAGE = `${SITE_URL}/og-default.png`;

const {
  title = DEFAULT_TITLE,
  description = DEFAULT_DESCRIPTION,
  canonical = Astro.url.href,
  ogTitle = title,
  ogDescription = description,
  ogImage = DEFAULT_OG_IMAGE,
  person = false,
} = Astro.props;

const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Nestor Angulo de Ugarte',
  url: SITE_URL,
  jobTitle: 'Head of Security',
  description: DEFAULT_DESCRIPTION,
  knowsAbout: [
    'Security Program Building',
    'Incident Response',
    'Vulnerability Intelligence',
    'Governance Risk and Compliance',
    'CISSP',
  ],
  hasCredential: {
    '@type': 'EducationalOccupationalCredential',
    credentialCategory: 'certification',
    name: 'CISSP',
    issuedBy: { '@type': 'Organization', name: 'ISC2' },
  },
  memberOf: {
    '@type': 'Organization',
    name: 'ISC2 Spain Chapter',
    roleName: 'Head of Technology',
  },
  sameAs: [
    'https://linkedin.com/in/pharar',
    'https://github.com/pharar',
    'https://x.com/pharar',
    'https://bsky.app/profile/nestorangulo.pro',
    'https://orcid.org/0000-0001-6605-7761',
    'https://gravatar.com/pharar',
  ],
};
---

<title>{title}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonical} />
<meta name="robots" content="index, follow" />
<meta name="color-scheme" content="light" />
<meta name="theme-color" content="#faf9f7" />

<!-- Open Graph -->
<meta property="og:type" content="website" />
<meta property="og:site_name" content="Nestor Angulo de Ugarte" />
<meta property="og:title" content={ogTitle} />
<meta property="og:description" content={ogDescription} />
<meta property="og:url" content={canonical} />
<meta property="og:image" content={ogImage} />
<meta property="og:locale" content="en_US" />

<!-- Twitter / X card -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={ogTitle} />
<meta name="twitter:description" content={ogDescription} />
<meta name="twitter:image" content={ogImage} />

<!-- Person structured data (homepage only) -->
{person && <script is:inline type="application/ld+json" set:html={JSON.stringify(personSchema)} />}
